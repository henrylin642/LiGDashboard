{
    "functions": {
        "api/cron/sync_lig_cache.ts": {
            "includeFiles": "public/data/scandata.csv",
            "maxDuration": 60
        }
    },
    "rewrites": [
        {
            "source": "/api/lig/(.*)",
            "destination": "/api/lig?path=$1"
        },
        {
            "source": "/((?!api/.*).*)",
            "destination": "/index.html"
        }
    ]
}